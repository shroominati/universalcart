{
  "manifest_version": 3,
  "name": "UniversalCart",
  "version": "0.1.0",
  "description": "Shop everywhere. Checkout once. Every transaction step produces a typed, inspectable claim envelope.",
  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Open UniversalCart"
  }
}
